# ============================================================
# CHURCH MEDIA APP — Environment Variables
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database (Aiven MySQL)
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=3306
DB_NAME=church_media_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=https://your-backend.onrender.com/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx

# App
FRONTEND_URL=http://localhost:3000
MAX_FILE_SIZE_MB=500
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com
